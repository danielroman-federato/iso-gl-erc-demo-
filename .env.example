# Frontend env vars (Vite — only VITE_* vars are exposed to client code).
# Copy to .env.local and edit as needed.

# Point the api client at a remote backend. Leave blank to use the Vite proxy in dev,
# or the same-origin /api path in production.
# VITE_API_BASE=http://localhost:8000

# Mock mode — when "1", api/client.js short-circuits fetch() and returns local fixtures
# from src/api/fixtures/. Use this for the Vercel design-prototype deploy where no
# backend is available. Set VITE_MOCK=1 in Vercel project env vars.
# VITE_MOCK=1
